@page
@model LabelVerify.Web.Pages.Reviews.IndexModel
@using System.Text.Json

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
<div class="container mt-4">
    <h2>Review History</h2>
    <div class="alert alert-primary">
        Historical compliance reviews stored in Azure SQL.
    </div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Review Operations Dashboard</h2>
        <div>
            <a asp-page="./WorkQueue" class="btn btn-primary"">Work Queue</a>
            <a asp-page-handler="MonthlyReport" class="btn btn-primary">Generate Monthly Compliance Report</a>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Metrics.OperationalInsights))
    {
        <div class="card mb-4">
            <div class="card-header">
                <strong>AI Operational Insights</strong>
            </div>
            <div class="card-body">
                <div style="white-space: pre-line;">
                    @Model.Metrics.OperationalInsights
                </div>
            </div>
        </div>
        <div class="text-muted small mt-3">
            Generated:
            @Model.Metrics.OperationalInsightsGeneratedUtc?.ToLocalTime().ToString("g")
            <br />
            Model:
            @Model.Metrics.OperationalInsightsModel
        </div><br />
    }

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card border-primary text-center h-100">
                <div class="card-body">
                    <h6>Open Reviews</h6>
                    <h3>@Model.Metrics.TotalOpenReviews</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-info text-center h-100">
                <div class="card-body">
                    <h6>Active Reviewers</h6>
                    <h3>@Model.Metrics.ActiveReviewers</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-secondary text-center h-100">
                <div class="card-body">
                    <h6>Reviews Per Reviewer</h6>
                    <h3>@Model.Metrics.ReviewsPerReviewer.ToString("0.0")</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card border-danger text-center h-100">
                <div class="card-body">
                    <h6>High Risk Reviews</h6>
                    <h2>@Model.Metrics.HighRiskReviews</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-warning text-center h-100">
                <div class="card-body">
                    <h6>Medium Risk Reviews</h6>
                    <h2>@Model.Metrics.MediumRiskReviews</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-success text-center h-100">
                <div class="card-body">
                    <h6>Low Risk Reviews</h6>
                    <h2>@Model.Metrics.LowRiskReviews</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="card mb-4">
        <div class="card-header">
            <strong>Priority Review Queue</strong>
        </div>
        <div class="card-body">
            <table class="table table-sm">
                <thead>
                    <tr>
                        <th>Risk</th>
                        <th>Review</th>
                        <th>Recommendation</th>
                        <th>Reviewer</th>
                        <th>Days Open</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Metrics.PriorityQueue)
                    {
                        <tr>

                            <td>
                                @if (item.RiskLevel == "High")
                                {
                                    <span class="badge bg-danger">
                                        @item.RiskScore
                                    </span>
                                }
                                else if (item.RiskLevel == "Medium")
                                {
                                    <span class="badge bg-warning text-dark">
                                        @item.RiskScore
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-success">
                                        @item.RiskScore
                                    </span>
                                }
                            </td>
                            <td>@item.BrandName</td>
                            <td>@item.Recommendation</td>
                            <td>
                                @(string.IsNullOrWhiteSpace(item.AssignedReviewer) ? "Unassigned" : item.AssignedReviewer)
                            </td>
                            <td>@item.DaysOpen</td>
                            <td>
                                <a asp-page="/Reviews/Details" asp-route-id="@item.ReviewId" class="btn btn-sm btn-primary">Open</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(Model.Metrics.QueueRecommendation))
    {
        <div class="card mb-4">
            <div class="card-header">
                <strong>AI Queue Recommendation</strong>
            </div>
            <div class="card-body">
                <div style="white-space: pre-line;">
                    @Model.Metrics.QueueRecommendation
                </div>
                <hr />
                <div class="text-muted small">
                    Generated:
                    @Model.Metrics.QueueRecommendationGeneratedUtc?.ToLocalTime().ToString("g")
                    <br />
                    Model:
                    @Model.Metrics.QueueRecommendationModel
                </div>
            </div>
        </div>
    }

    <div class="alert alert-info">
        Leaderboard Count: @Model.Metrics.ReviewerLeaderboard.Count
    </div>
    <div class="row mb-4">
        <div class="col-md-7">
            <div class="card mb-4">
                <div class="card-header">
                    <strong>Reviewer Productivity Leaderboard</strong>
                </div>
                <div class="card-body">
                    <table class="table table-striped">
                        <thead>
                            <tr>
                                <th>Reviewer</th>
                                <th>Completed</th>
                                <th>Avg Hours</th>
                                <th>Approval %</th>
                                <th>Review %</th>
                                <th>Reject %</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (!Model.Metrics.ReviewerLeaderboard.Any())
                            {
                                <tr>
                                    <td colspan="6" class="text-center text-muted">
                                        No completed reviewer activity found.
                                    </td>
                                </tr>
                            }
                            else
                            {
                                @foreach (var reviewer in Model.Metrics.ReviewerLeaderboard)
                                {
                                    <tr>
                                        <td>@reviewer.ReviewerName</td>
                                        <td>@reviewer.ReviewsCompleted</td>
                                        <td>@reviewer.AverageReviewHours.ToString("0.0")</td>
                                        <td>@reviewer.ApprovalRate.ToString("0.0")%</td>
                                        <td>@reviewer.ReviewRate.ToString("0.0")%</td>
                                        <td>@reviewer.RejectionRate.ToString("0.0")%</td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-5">
            <div class="card mb-4">
                <div class="card-header">
                    <strong>Reviewer Productivity Chart</strong>
                </div>
                <div class="card-body">
                    <div style="height:300px;">
                        <canvas id="reviewerProductivityChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header">
                    <strong>Top Compliance Findings</strong>
                </div>
                <div class="card-body">
                    <table class="table table-sm mb-0">
                        <thead>
                            <tr>
                                <th>Field</th>
                                <th>Findings</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var finding in Model.Metrics.TopFindings)
                            {
                                <tr>
                                    <td>@finding.FieldName</td>
                                    <td>@finding.FindingCount</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header">
                    <strong>Top Compliance Findings Chart</strong>
                </div>
                <div class="card-body">
                    <div style="height:350px;">
                        <canvas id="topFindingsChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card h-100">
                <div class="card-header">
                    <strong>Findings by Month</strong>
                </div>
                <div class="card-body">
                    <div style="height:300px;">
                        <canvas id="findingsByMonthChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card h-100 border-primary">
                <div class="card-body text-center">
                    <h6>Total Reviews</h6>
                    <h2>@Model.Metrics.TotalReviews</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 border-success">
                <div class="card-body text-center">
                    <h6>Approved</h6>
                    <h2>@Model.Metrics.Approved</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 border-warning">
                <div class="card-body text-center">
                    <h6>Review</h6>
                    <h2>@Model.Metrics.InReview</h2>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100 border-danger">
                <div class="card-body text-center">
                    <h6>Rejected</h6>
                    <h2>@Model.Metrics.Rejected</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-info text-center h-100">
                <div class="card-body">
                    <h6>Average Review Time</h6>
                    <h3>@Model.Metrics.AverageReviewHours.ToString("0.0") Hours</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-success text-center h-100">
                <div class="card-body">
                    <h6>Fastest Reviewer</h6>
                    <h5>@Model.Metrics.FastestReviewer</h5>
                    <div class="text-muted">
                        @Model.Metrics.FastestReviewerAverageHours.ToString("0.0") Hours Avg
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning text-center h-100">
                <div class="card-body">
                    <h6>Oldest Open Review</h6>
                    <h3>@Model.Metrics.OldestOpenReviewDays Days</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-danger text-center h-100">
                <div class="card-body">
                    <h6>Reviews Exceeding SLA</h6>
                    <h3>@Model.Metrics.ReviewsExceedingSla</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-success text-center h-100">
                <div class="card-body">
                    <h6>Approval Rate</h6>
                    <h3>@Model.Metrics.ApprovalRate.ToString("0.0")%</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning text-center h-100">
                <div class="card-body">
                    <h6>Review Rate</h6>
                    <h3>@Model.Metrics.ReviewRate.ToString("0.0")%</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-danger text-center h-100">
                <div class="card-body">
                    <h6>Rejection Rate</h6>
                    <h3>@Model.Metrics.RejectionRate.ToString("0.0")%</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-warning text-center">
                <div class="card-body">
                    <h6>Over 7 Days</h6>
                    <h3>@Model.Metrics.AgingOver7Days</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card border-danger text-center">
                <div class="card-body">
                    <h6>Over 14 Days</h6>
                    <h3>@Model.Metrics.AgingOver14Days</h3>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card border-info text-center h-100">
                <div class="card-body">
                    <h6>Average Review Time</h6>
                    <h3>@Model.Metrics.AverageReviewHours.ToString("0.0") Hours</h3>
                </div>
            </div>
        </div>
    </div>
    <div class="card mb-4">
        <div class="card-header">
            Operational Insights
        </div>
        <div class="card-body">
            @foreach (var insight in Model.OperationalInsights)
            {
                <div class="alert alert-info mb-2">
                    @insight
                </div>
            }
        </div>
    </div>
    <div class="row mb-4">
        <div class="col-md-3">
            <a asp-page="./Index" asp-route-AssignedReviewer="Brian Cole" asp-route-WorkflowStatus="Assigned" class="text-decoration-none">
                <div class="card border-primary text-center h-100">
                    <div class="card-body">
                        <h6>My Assigned</h6>
                        <h3>@Model.Metrics.MyAssigned</h3>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a asp-page="./Index" asp-route-AssignedReviewer="Brian Cole" asp-route-WorkflowStatus="In Review" class="text-decoration-none">
                <div class="card border-warning text-center h-100">
                    <div class="card-body">
                        <h6>My In Review</h6>
                        <h3>@Model.Metrics.MyInReview</h3>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a asp-page="./Index" asp-route-AssignedReviewer="Brian Cole" asp-route-FinalDisposition="Approve" class="text-decoration-none">
                <div class="card border-success text-center h-100">
                    <div class="card-body">
                        <h6>My Completed</h6>
                        <h3>@Model.Metrics.MyCompleted</h3>
                    </div>
                </div>
            </a>
        </div>
        <div class="col-md-3">
            <a asp-page="./Index" asp-route-AssignedReviewer="Unassigned" asp-route-WorkflowStatus="Submitted" class="text-decoration-none">
                <div class="card border-secondary text-center h-100">
                    <div class="card-body">
                        <h6>Unassigned</h6>
                        <h3>@Model.Metrics.Unassigned</h3>
                    </div>
                </div>
            </a>
        </div>
    </div>
    <div class="row mb-4">
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-header">
                    Workflow Status Distribution
                </div>
                <div class="card-body">
                    <div style="height:300px;">
                        <canvas id="workflowChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-header">
                    Reviews by Month
                </div>
                <div class="card-body">
                    <div style="height:300px;">
                        <canvas id="monthlyReviewChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-header">
                    Top Failure Reasons
                </div>
                <div class="card-body">
                    <div style="height:300px;">
                        <canvas id="topFailureChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="card h-100">
                <div class="card-header">
                    Reviewer Productivity
                </div>
                <div class="card-body">
                    <div style="height:300px;">
                        <canvas id="reviewerProductivityChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="card mb-4">
        <div class="card-header">
            <strong>Top Failure Reasons</strong>
        </div>
        <div class="card-body">
            @if (Model.TopFailures.Any())
            {
                <table class="table table-striped mb-0">
                    <thead>
                        <tr>
                            <th>Field</th>
                            <th class="text-end">Failures</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var failure in Model.TopFailures)
                        {
                            <tr>
                                <td>@failure.FieldName</td>
                                <td class="text-end">@failure.Count</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-success mb-0">No failures recorded.</div>
            }
        </div>
    </div>
    <div class="row mb-4">
        <div class="col-md-12">
            <div class="card">
                <div class="card-body text-center">
                    <h6>Average Compliance Score</h6>
                    <h2>@Model.Metrics.AverageScore.ToString("N1")%</h2>
                </div>
            </div>
        </div>
    </div>
    <div class="row mb-4">
        <div class="col">
            <div class="card text-center border-secondary">
                <div class="card-body">
                    <h6>Submitted</h6>
                    <h3>@Model.Metrics.Submitted</h3>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card text-center border-primary">
                <div class="card-body">
                    <h6>Assigned</h6>
                    <h3>@Model.Metrics.Assigned</h3>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card text-center border-warning">
                <div class="card-body">
                    <h6>In Review</h6>
                    <h3>@Model.Metrics.InReview</h3>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card text-center border-success">
                <div class="card-body">
                    <h6>Approved</h6>
                    <h3>@Model.Metrics.Approved</h3>
                </div>
            </div>
        </div>
        <div class="col">
            <div class="card text-center border-danger">
                <div class="card-body">
                    <h6>Rejected</h6>
                    <h3>@Model.Metrics.Rejected</h3>
                </div>
            </div>
        </div>
    </div>
    <form method="get" class="card mb-4">
        <div class="col-md-12 d-flex align-items-end">
            <div class="btn-group w-100">
                <button class="btn btn-primary">Search</button>&nbsp;
                <a asp-page="./Index" class="btn btn-secondary">Clear</a>
            </div>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-3">
                    <label>Recommendation</label>
                    <select asp-for="Recommendation" class="form-select">
                        <option value="">All</option>
                        <option>Approve</option>
                        <option>Review</option>
                        <option>Reject</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label>Minimum Score</label>
                    <input asp-for="MinimumScore" class="form-control" />
                </div>
                <div class="col-md-3">
                    <label>COLA Package</label>
                    <input asp-for="ColaPackageFileName" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label>Start Date (Local)</label>
                    <input asp-for="StartDate" type="date" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label>End Date (Local)</label>
                    <input asp-for="EndDate" type="date" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label>Status</label>

                    <select asp-for="WorkflowStatus" class="form-select">
                        <option value="">All</option>
                        <option>Submitted</option>
                        <option>Assigned</option>
                        <option>In Review</option>
                        <option>Approved</option>
                        <option>Rejected</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label>Assigned To</label>
                    <select asp-for="AssignedReviewer" class="form-select">
                        <option value="">All</option>
                        <option>Unassigned</option>
                        <option>Brian Cole</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label>Final Decision</label>
                    <select asp-for="FinalDisposition" class="form-select">
                        <option value="">All</option>
                        <option>Approve</option>
                        <option>Review</option>
                        <option>Reject</option>
                    </select>
                </div>
            </div>
        </div>
    </form>
    <div class="mb-2 text-muted">
        Showing @Model.Reviews.Count of @Model.TotalRecords reviews
    </div>
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th style="width:120px;">Date</th>
                <th class="text-center">Age (Days)</th>
                <th class="text-center" style="width:160px;">Recommendation</th>
                <th class="text-center" style="width:160px;">Final Decision</th>
                <th class="text-center" style="width:60px;">Score</th>
                <th class="text-center">Proc. Time&nbsp;(ms)</th>
                <th>COLA Package</th>
                <th class="text-center" style="width:120px;">Status</th>
                <th>Assigned&nbsp;To</th>
                <th class="text-center" style="width:140px;">Actions</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var review in Model.Reviews)
            {
                <tr>
                    <td class="align-middle">@review.ReviewDateUtc.ToLocalTime()</td>
                    <td class="align-middle text-center">
                        @{var ageDays = (DateTime.UtcNow - review.ReviewDateUtc).Days;}
                        @{var ageClass = ageDays switch
                            {
                                <= 3 => "review-status-tile bg-success text-white",
                                <= 7 => "review-status-tile bg-warning text-dark",
                                _ => "review-status-tile bg-danger text-white"
                            };
                        }
                        <span class="@ageClass">
                            @ageDays
                        </span>
                    </td>
                    <td class="align-middle">
                        @if (review.Recommendation == "Approve")
                        {
                            <div class="review-status-tile bg-success text-white">
                                @review.Recommendation
                            </div>
                        }
                        else if (review.Recommendation == "Review")
                        {
                            <div class="review-status-tile bg-warning text-dark">
                                @review.Recommendation
                            </div>
                        }
                        else
                        {
                            <div class="review-status-tile bg-danger text-white">
                                @review.Recommendation
                            </div>
                        }
                    </td>
                    <td class="text-center align-middle">
                        @{var decision = review.FinalDisposition;}

                        @if (string.IsNullOrWhiteSpace(decision))
                        {
                            <div class="review-status-tile bg-secondary text-white">
                                Pending
                            </div>
                        }
                        else
                        {
                            var decisionClass = decision switch
                            {
                                "Approve" => "bg-success text-white",
                                "Review" => "bg-warning text-dark",
                                "Reject" => "bg-danger text-white",
                                _ => "bg-secondary text-white"
                            };

                            <div class="review-status-tile @decisionClass">
                                @decision
                            </div>
                        }
                    </td>
                    <td class="text-center align-middle">@review.OverallScore%</td>
                    <td class="text-center align-middle">@review.ProcessingTimeMs</td>
                    <td class="align-middle">@review.ColaPackageFileName</td>
                    <td class="text-center align-middle">
                        @{
                            var statusClass = review.WorkflowStatus switch
                            {
                                "Submitted" => "review-status-tile bg-secondary text-white",
                                "In Review" => "review-status-tile bg-warning text-dark",
                                "Approved" => "review-status-tile bg-success text-white",
                                "Rejected" => "review-status-tile bg-danger text-white",
                                _ => "bg-secondary"
                            };
                        }

                        <span class="@statusClass">
                            @review.WorkflowStatus
                        </span>
                    </td>
                    <td class="align-middle">
                        @if (string.IsNullOrWhiteSpace(review.AssignedReviewer))
                        {
                            <span>Unassigned</span>
                        }
                        else
                        {
                            <span>@review.AssignedReviewer</span>
                        }
                    </td>
                    <td class="align-middle">
                        <a asp-page="./Details" asp-route-id="@review.Id" class="review-status-tile bg-primary text-white text-decoration-none">
                            View
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
<nav>
    <ul class="pagination justify-content-center">
        <li class="page-item @(Model.PageNumber == 1 ? "disabled" : "")">
            <a class="page-link"
               asp-page="./Index"
               asp-route-PageNumber="@(Model.PageNumber - 1)"
               asp-route-Recommendation="@Model.Recommendation"
               asp-route-MinimumScore="@Model.MinimumScore"
               asp-route-ColaPackageFileName="@Model.ColaPackageFileName"
               asp-route-StartDate="@Model.StartDate?.ToString("yyyy-MM-dd")"
               asp-route-EndDate="@Model.EndDate?.ToString("yyyy-MM-dd")"
               asp-route-WorkflowStatus="@Model.WorkflowStatus"
               asp-route-AssignedReviewer="@Model.AssignedReviewer"
               asp-route-FinalDisposition="@Model.FinalDisposition">
                Previous
            </a>
        </li>

        @for (var i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                <a class="page-link"
                   asp-page="./Index"
                   asp-route-PageNumber="@i"
                   asp-route-Recommendation="@Model.Recommendation"
                   asp-route-MinimumScore="@Model.MinimumScore"
                   asp-route-ColaPackageFileName="@Model.ColaPackageFileName"
                   asp-route-StartDate="@Model.StartDate?.ToString("yyyy-MM-dd")"
                   asp-route-EndDate="@Model.EndDate?.ToString("yyyy-MM-dd")">
                    @i
                </a>
            </li>
        }

        <li class="page-item @(Model.PageNumber == Model.TotalPages ? "disabled" : "")">
            <a class="page-link"
               asp-page="./Index"
               asp-route-PageNumber="@(Model.PageNumber + 1)"
               asp-route-Recommendation="@Model.Recommendation"
               asp-route-MinimumScore="@Model.MinimumScore"
               asp-route-ColaPackageFileName="@Model.ColaPackageFileName"
               asp-route-StartDate="@Model.StartDate?.ToString("yyyy-MM-dd")"
               asp-route-EndDate="@Model.EndDate?.ToString("yyyy-MM-dd")">
                Next
            </a>
        </li>
    </ul>
</nav>

@section Scripts
{
    <script>
        const workflowChart = document.getElementById('workflowChart');

        new Chart(workflowChart, {
            type: 'doughnut',
            data: {
            labels:
            @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize(Model.WorkflowChart.Labels)),
                datasets: [{
                    data:
                    @Html.Raw(
                        System.Text.Json.JsonSerializer.Serialize(
                            Model.WorkflowChart.Values))
                    }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false
            }
