@page "{id:guid}"
@model LabelVerify.Web.Pages.Reviews.DetailsModel

<div class="container mt-4">
    <h2>Review Details</h2>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a asp-page="./Index" class="btn btn-secondary">
            ← Back to Review History
        </a>
        <div>
            <strong>Review ID:</strong>
            @Model.Review?.Id
        </div>
    </div>

    @if (Model.Review != null)
    {
        <div class="d-flex gap-2 mb-3">
            <a asp-page-handler="ExportPdf" asp-route-id="@Model.Review.Id" class="btn btn-success">Export PDF</a>
            <a asp-page-handler="ExportCsv" asp-route-id="@Model.Review.Id" class="btn btn-success">Export CSV</a>
            <a asp-page-handler="ExportZip" asp-route-id="@Model.Review.Id" class="btn btn-success">Export ZIP</a>
        </div>
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card h-100">
                    <div class="card-body text-center d-flex flex-column justify-content-center">
                        <h6>Recommendation</h6>
                        <h3>@Model.Review.Recommendation</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100">
                    <div class="card-body text-center d-flex flex-column justify-content-center">
                        <h6>Score</h6>
                        <h3>@Model.Review.OverallScore%</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100">
                    <div class="card-body text-center d-flex flex-column justify-content-center">
                        <h6>Status</h6>
                        <h3>@Model.Review.WorkflowStatus</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100">
                    <div class="card-body text-center d-flex flex-column justify-content-center">
                        <h6>Review Date</h6>
                        <h5 class="mb-0">
                            @Model.Review.ReviewDateUtc.ToLocalTime().ToString("g")
                        </h5>
                    </div>
                </div>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(Model.Review.AiComplianceSummary))
        {
            <div class="alert alert-info mb-3">
                <strong>AI-Assisted Narrative</strong>
                <span class="badge bg-primary ms-2">
                    Confidence @Model.Review.OverallScore%
                </span>
                <div class="small mt-2">
                    Generated from OCR extraction, field comparisons,
                    confidence scoring, and deterministic compliance results.
                    Final approval decisions remain under reviewer control.
                </div>
            </div>
            <div class="card mb-4">
                <div class="card-header">
                    <strong>AI Compliance Summary</strong>
                </div>
                <div class="card-body">
                    <div style="white-space:pre-line;">
                        @Model.Review.AiComplianceSummary
                    </div>
                    <div class="text-muted small mt-2">
                        Generated @Model.Review.AiSummaryGeneratedUtc?.ToLocalTime().ToString("g")
                        using @Model.Review.AiModelUsed
                    </div>
                </div>
            </div>
        }

        <div class="card mb-4">
            <div class="card-header">
                <strong>Reviewer Decision</strong>
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="Disposition">
                    <input type="hidden" name="id" value="@Model.Review.Id" />
                    <div class="row">
                        <div class="col-md-3">
                            <label class="form-label">Reviewer</label>
                            <input asp-for="ReviewerName" class="form-control" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label">Final Disposition</label>
                            <select asp-for="FinalDisposition" class="form-select">
                                <option>Approve</option>
                                <option>Review</option>
                                <option>Reject</option>
                            </select>
                        </div>
                    </div>
                    <div class="mt-3">
                        <label class="form-label">Reviewer Notes</label>
                        <textarea asp-for="ReviewerNotes" rows="4" class="form-control"></textarea>
                    </div>
                    <div class="mt-3">
                        <button type="submit" class="btn btn-success">
                            Save Decision
                        </button>
                    </div>
                </form>
            </div>
        </div>
        <div class="card mb-4">
            <div class="card-header">
                <strong>Field Validation Results</strong>
            </div>
            <div class="card-body">
                <table class="table table-bordered table-striped mb-0">
                    <thead>
                        <tr>
                            <th style="width:180px;">Field</th>
                            <th>Approved</th>
                            <th>Production</th>
                            <th>Found On</th>
                            <th class="text-center" style="width:100px;">Status</th>
                            <th class="text-center">Confidence</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Review.Results)
                        {
                            <tr>
                                <td>@item.FieldName</td>
                                <td>@item.ExpectedValue</td>
                                <td>@item.ActualValue</td>
                                <td>@item.SourceLabel</td>
                                <td>
                                    @if (item.Status == "Pass")
                                    {
                                        <span class="badge bg-success d-flex justify-content-center align-items-center w-100 py-2">
                                            Pass
                                        </span>
                                    }
                                    else if (item.Status == "Review")
                                    {
                                        <span class="badge bg-warning text-dark d-flex justify-content-center align-items-center w-100 py-2">
                                            Review
                                        </span>
                                    }
                                    else if (item.Status == "Skipped")
                                    {
                                        <span class="badge bg-secondary d-flex justify-content-center align-items-center w-100 py-2">
                                            Skipped
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger d-flex justify-content-center align-items-center w-100 py-2">
                                            Fail
                                        </span>
                                    }
                                </td>
                                <td class="text-center">
                                    @if (item.Status == "Skipped")
                                    {
                                        <span>N/A</span>
                                    }
                                    else
                                    {
                                        <span>@item.ConfidenceScore%</span>
                                    }
                                </td>
                            </tr>

                            @if (!string.IsNullOrWhiteSpace(item.AiAnalysis))
                            {
                                <tr>
                                    <td colspan="6" class="bg-light">
                                        <div class="p-3">
                                            <div class="fw-bold mb-2">
                                                AI Analysis
                                            </div>
                                            <div style="white-space: pre-line;">
                                                @item.AiAnalysis
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>
        </div>
        <div class="card mb-4">
            <div class="card-header">
                <strong>Source Documents</strong>
            </div>
            <div class="card-body">
                @if (!string.IsNullOrWhiteSpace(Model.ColaPackageDownloadUrl))
                {
                    <a href="@Model.ColaPackageDownloadUrl" target="_blank" class="btn btn-primary me-2">Download COLA Package</a>
                }

                @if (Model.ProductionLabelDownloadUrls.Any())
                {
                    <hr />
                    <h6>Production Labels</h6>

                    @for (var i = 0; i < Model.ProductionLabelDownloadUrls.Count; i++)
                    {
                        <a href="@Model.ProductionLabelDownloadUrls[i]" target="_blank" class="btn btn-outline-secondary me-2 mb-2">Label @(i + 1)</a>
                    }
                }
            </div>
        </div>
        <div class="card mb-4">
            <div class="card-header">
                <strong>Assignment</strong>
            </div>
            <div class="card-body">
                <form method="post" asp-page-handler="Assign" asp-route-id="@Model.Review.Id">
                    <div class="row">
                        <div class="col-md-4">
                            <label class="form-label">
                                Assigned Reviewer
                            </label>
                            <input asp-for="AssignedReviewer" class="form-control" />
                        </div>
                    </div>
                    <button type="submit" class="btn btn-primary mt-3">
                        Assign Reviewer
                    </button>
                </form>
            </div>
        </div>
        <div class="card mb-4">
            <div class="card-header">
                <strong>Audit Trail</strong>
            </div>
            <div class="card-body">
                <table class="table table-sm mb-0">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Event</th>
                            <th>Message</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model.AuditLogs)
                        {
                            <tr>
                                <td>@log.TimestampUtc.ToLocalTime()</td>
                                <td>@log.EventType</td>
                                <td>@log.Message</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    }
</div>