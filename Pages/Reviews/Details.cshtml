@page "{id:guid}"
@model LabelVerify.Web.Pages.Reviews.DetailsModel

<div class="d-flex gap-2 mb-3">
    <a asp-page-handler="ExportPdf" asp-route-id="@Model.Review!.Id" class="btn btn-success">Export PDF</a>

    <a asp-page-handler="ExportCsv" asp-route-id="@Model.Review!.Id" class="btn btn-success"> Export CSV</a>

    <a asp-page-handler="ExportZip" asp-route-id="@Model.Review!.Id" class="btn btn-success">Export ZIP</a>
</div>
<div class="container mt-4">
    <h2>Review Details</h2>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <a asp-page="./Index" class="btn btn-secondary">← Back to Review History</a>
        <div>
            <strong>Review ID:</strong>
            @Model.Review?.Id
        </div>
    </div>
    @if (Model.Review != null)
    {
        <div class="row mb-4" align-items-stretch">
            <div class="col-md-3">
                <div class="card h-100">
                    <div class="card">
                        <div class="card-body text-center d-flex flex-column justify-content-center" ">
                            <h6>Recommendation</h6>
                            <h3>@Model.Review.Recommendation</h3>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100">
                    <div class="card">
                        <div class="card-body text-center d-flex flex-column justify-content-center" ">
                            <h6>Score</h6>
                            <h3>@Model.Review.OverallScore%</h3>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100">
                    <div class="card">
                        <div class="card-body text-center d-flex flex-column justify-content-center" ">
                            <h6>Processing Time</h6>
                            <h3>@Model.Review.ProcessingTimeMs ms</h3>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card h-100">
                    <div class="card-body text-center d-flex flex-column justify-content-center">
                        <h6 class="mb-2">Review Date</h6>
                        <h5 class="mb-0">
                            @Model.Review.ReviewDateUtc.ToLocalTime().ToString("g")
                        </h5>
                    </div>
                </div>
            </div>
        </div>
        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th style="width:180px;">Field</th>
                    <th>Approved</th>
                    <th>Production</th>
                    <th>Found On</th>
                    <th class="text-center" style="width:100px;">Status</th>
                    <th class="text-center">Confidence</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Review.Results)
                {
                    <tr>
                        <td>@item.FieldName</td>
                        <td>@item.ExpectedValue</td>
                        <td>@item.ActualValue</td>
                        <td>@item.SourceLabel</td>
                        <td>
                            @if (item.Status == "Pass")
                            {
                                <span class="badge bg-success d-flex justify-content-center align-items-center w-100 py-2">Pass</span>
                            }
                            else if (item.Status == "Review")
                            {
                                <span class="badge bg-warning text-dark d-flex justify-content-center align-items-center w-100 py-2">Review</span>
                            }
                            else if (item.Status == "Skipped")
                            {
                                <span class="badge bg-secondary d-flex justify-content-center align-items-center w-100 py-2">Skipped</span>
                            }
                            else
                            {
                                <span class="badge bg-danger d-flex justify-content-center align-items-center w-100 py-2">Fail</span>
                            }
                        </td>
                        <td class="text-center">
                            @if (item.Status == "Skipped")
                            {
                                <span>N/A</span>
                            }
                            else
                            {
                                <span>@item.ConfidenceScore%</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>