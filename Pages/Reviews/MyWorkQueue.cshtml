@page
@model LabelVerify.Web.Pages.Reviews.MyWorkQueueModel

@{
    ViewData["Title"] = "My Work Queue";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>My Work Queue</h2>
    <a asp-page="/Reviews/Dashboard" class="btn btn-outline-secondary">← Back to Dashboard</a>
</div>
<div class="card mb-4">
    <div class="card-header">
        <strong>Assigned Reviews</strong>
    </div>
    <div class="card-body">
        @if (!Model.Packages.Any())
        {
            <div class="alert alert-success mb-0">
                No reviews currently assigned.
            </div>
        }
        else
        {
            <table class="table table-striped table-hover align-middle">
                <thead>
                    <tr>
                        <th>Source</th>
                        <th>Batch</th>
                        <th>COLA Package</th>
                        <th>Status</th>
                        <th>Assigned</th>
                        <th class="text-center">Days Open</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.Items)
                    {
                        <tr>
                            <td>@item.SourceType</td>
                            <td>@(item.BatchName ?? "-")</td>
                            <td>@item.Title</td>
                            <td>@item.Status</td>
                            <td>@(item.AssignedUtc?.ToLocalTime().ToString("g") ?? "-")</td>
                            <td class="text-center">@item.DaysOpen</td>
                            <td>
                                @if (item.SourceType == "Batch")
                                {
                                    <a asp-page="/Reviews/BatchPackage" asp-route-packageId="@item.Id" class="review-status-tile bg-primary text-white">
                                        Process
                                    </a>
                                }
                                else
                                {
                                    <a asp-page="/Reviews/Details" asp-route-id="@item.Id" class="review-status-tile bg-primary text-white">
                                        Open
                                    </a>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>