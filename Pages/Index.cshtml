@page
@model IndexModel

<div class="container mt-5">

    <div class="p-5 mb-4 bg-light rounded-3 border shadow-sm">
        <div class="container-fluid py-4">
            <h1 class="display-5 fw-bold">
                LabelVerify AI
            </h1>

            <p class="col-md-10 fs-5">
                AI-assisted alcohol label verification prototype designed to support
                TTB compliance agents with OCR, fuzzy matching, confidence scoring,
                batch processing, and human-in-the-loop review recommendations.
            </p>

            <hr />

            <p class="text-muted">
                Built as a standalone proof-of-concept for evaluating how automation
                can reduce routine manual verification while preserving agent judgment.
            </p>

            <a asp-page="/Single" class="btn btn-primary btn-lg me-2">
                Start Single Label Review
            </a>

            <a asp-page="/Batch" class="btn btn-outline-primary btn-lg">
                Open Batch Review
            </a>
        </div>
    </div>

    <div class="row">

        <div class="col-md-4">
            <div class="card h-100 border-primary">
                <div class="card-body">
                    <h5>Single Label Review</h5>
                    <p>
                        Upload one label and compare it against application data using
                        OCR-assisted verification and confidence scoring.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-success">
                <div class="card-body">
                    <h5>Batch Processing</h5>
                    <p>
                        Process multiple labels in one workflow to support large importer
                        submissions and high-volume review periods.
                    </p>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card h-100 border-warning">
                <div class="card-body">
                    <h5>Human Review Support</h5>
                    <p>
                        Uses Pass, Review, and Fail recommendations so agents retain final
                        compliance judgment for nuanced cases.
                    </p>
                </div>
            </div>
        </div>

    </div>

</div>